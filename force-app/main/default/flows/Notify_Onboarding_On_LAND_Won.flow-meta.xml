    </decisions>
    <environments>Default</environments>
    <formulas>
        <description>Fecha de vencimiento de la tarea = Fecha de Cierre + 3 dias habiles (aproximado saltando fines de semana). 1900-01-07 fue domingo, por lo que MOD(...,7): 0=Dom,1=Lun,...,6=Sab.</description>
        <name>fDueDate</name>
        <dataType>Date</dataType>
        <expression>CASE(MOD($Record.CloseDate - DATE(1900,1,7),7),
0, $Record.CloseDate + 4,
1, $Record.CloseDate + 3,
2, $Record.CloseDate + 3,
3, $Record.CloseDate + 5,
4, $Record.CloseDate + 5,
5, $Record.CloseDate + 5,
6, $Record.CloseDate + 4,
$Record.CloseDate + 3)</expression>
    </formulas>
    <formulas>
